datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
}


model User {
    id        Int      @id @default(autoincrement())
    discordId String   @unique
    name      String
    shipLevel Int      @default(0)
    xp        Int      @default(0)
    // Cambia DataTime por DateTime
    shipTime  DateTime @default(now()) 
}